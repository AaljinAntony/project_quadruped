// Final calibrated limits to protect mechanical structure
int joint_min_pwm[12] = {274, 286, 265, 291, 228, 255, 127, 241, 237, 131, 245, 296};
int joint_max_pwm[12] = {495, 366, 330, 485, 386, 323, 323, 426, 373, 327, 398, 387};

// These are the values found via interactive calibration (last known good position).
float joint_offsets[12] = {
  363, // 0: FL Foot (Pin 0)
  297, // 1: FL Leg (Pin 1)
  296, // 2: FL Shoulder (Pin 2)
  371, // 3: RL Foot (Pin 4)
  288, // 4: RL Leg (Pin 5)
  299, // 5: RL Shoulder (Pin 6)
  236, // 6: FR Foot (Pin 8)
  316, // 7: FR Leg (Pin 9)
  315, // 8: FR Shoulder (Pin 10)
  245, // 9: RR Foot (Pin 12)
  331, // 10: RR Leg (Pin 13)
  326  // 11: RR Shoulder (Pin 14)
};

// --- JOINT MAPPING ---
// Maps the exact ROS 2 joint string name to the physical PCA9685 pin (0-11)
struct JointMap {
  const char* name;
  int pca_pin;
  int offset_index;
};

JointMap joint_mapping[12] = {
  {"foot_motor_front_left", 0, 0},
  {"motor_front_left_leg", 1, 1},
  {"motor_front_left_shoulder", 2, 2},
  {"foot_motor_rear_left", 4, 3},
  {"motor_rear_left_leg", 5, 4},
  {"motor_rear_left_shoulder", 6, 5},
  {"foot_motor_front_right", 8, 6},
  {"motor_front_right_leg", 9, 7},
  {"motor_front_right_shoulder", 10, 8},
  {"foot_motor_rear_right", 12, 9},
  {"motor_rear_right_leg", 13, 10},
  {"motor_rear_right_shoulder", 14, 11}
};

// --- MICRO-ROS VARIABLES ---
rcl_subscription_t subscriber;
