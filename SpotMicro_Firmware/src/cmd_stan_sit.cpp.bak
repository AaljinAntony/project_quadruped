#include <Arduino.h>
#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

Adafruit_PWMServoDriver pwm = Adafruit_PWMServoDriver(0x40);

#define SERVO_FREQ 50

// Calibrated Neutral PWM Offsets from AGENT_MEMORY.md
struct JointOffset {
    int pin;
    int neutral;
    const char* name;
};

JointOffset offsets[12] = {
    {0, 363, "FL Foot"},
    {1, 297, "FL Leg"},
    {2, 296, "FL Shoulder"},
    {4, 371, "RL Foot"},
    {5, 288, "RL Leg"},
    {6, 299, "RL Shoulder"},
    {8, 236, "FR Foot"},
    {9, 316, "FR Leg"},
    {10, 315, "FR Shoulder"},
    {12, 245, "RR Foot"},
    {13, 331, "RR Leg"},
    {14, 326, "RR Shoulder"}
};

void setup() {
    Serial.begin(115200);
    delay(1000);
    Serial.println("--- SpotMicro NEUTRAL STANCE HOLD ---");
    Serial.println("Initializing PCA9685...");

    pwm.begin();
    pwm.setOscillatorFrequency(27000000);
    pwm.setPWMFreq(SERVO_FREQ);

    delay(500);

    Serial.println("Powering servos to Neutral Stance...");
    for(int i = 0; i < 12; i++) {
        Serial.printf("Setting %s (Pin %d) to %d\n", offsets[i].name, offsets[i].pin, offsets[i].neutral);
        pwm.setPWM(offsets[i].pin, 0, offsets[i].neutral);
        delay(50); // Small stagger to avoid current spikes
    }

    Serial.println("Stance Established. Robot should be holding neutral pose.");
}

void loop() {
    // Keep internal loop alive, but just hold positions
    static unsigned long last_print = 0;
    if (millis() - last_print > 5000) {
        Serial.println("Still holding Neutral Stance...");
        last_print = millis();
    }
    delay(10);
}
